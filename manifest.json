{
    "manifest_version": 3,
    "name": "GarminConnect PacePro loader",
    "version": "1.0.0",
    "browser_specific_settings": {
        "gecko": {
            "id": "CustomPaceProLoader@maslowski.cz",
            "data_collection_permissions": {
                "required": ["websiteContent"],
                "optional": []
            }
        }
    },
    "description": "Adds a button to load custom PacePro strategies on Garmin Connect course detail view.",
    "permissions": [],
    
    "host_permissions": [
        "https://connect.garmin.com/"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://connect.garmin.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ]
}